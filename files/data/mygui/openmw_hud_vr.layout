<?xml version="1.0" encoding="UTF-8"?>

<MyGUI type="Layout">
  <Widget type="Widget" layer="HUD_3D" position="0 0 520 242" name="_Main" align="Default">
    <!-- Energy bars -->
    <Widget type="ProgressBar" skin="MW_EnergyBar_Yellow" position="8 8 260 16" align="Left Top" name="EnemyHealth">
      <Property key="Visible" value="false"/>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="8 12 42 24" name="HealthLabel" align="Left Top">
      <Property key="Caption" value="HP"/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="TextColour" value="0.25 1 0.25"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>
    <Widget type="Button" skin="" position="50 12 260 24" align="Left Top" name="HealthFrame">
      <UserString key="ToolTipType" value="Layout"/>
      <UserString key="ToolTipLayout" value="HealthToolTip"/>
      <UserString key="ImageTexture_HealthImage" value="icons\k\health.dds"/>
      <Widget type="ProgressBar" skin="MW_EnergyBar_Green" position="0 0 260 24" align="Left Top" name="Health">
        <Property key="NeedMouse" value="false"/>
      </Widget>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="322 12 118 24" name="HealthValue" align="Left Top">
      <Property key="Caption" value="--/--"/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="TextColour" value="0.25 1 0.25"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="8 44 42 24" name="MagickaLabel" align="Left Top">
      <Property key="Caption" value="AP"/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="TextColour" value="0.25 1 0.25"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>
    <Widget type="Button" skin="" position="50 44 260 24" align="Left Top" name="MagickaFrame">
      <UserString key="ToolTipType" value="Layout"/>
      <UserString key="ToolTipLayout" value="HealthToolTip"/>
      <UserString key="ImageTexture_HealthImage" value="icons\k\magicka.dds"/>
      <Widget type="ProgressBar" skin="MW_EnergyBar_Green" position="0 0 260 24" align="Left Top" name="Magicka">
        <Property key="NeedMouse" value="false"/>
      </Widget>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="322 44 118 24" name="MagickaValue" align="Left Top">
      <Property key="Caption" value="--/--"/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="TextColour" value="0.25 1 0.25"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="444 12 68 24" name="ArmorValue" align="Left Top">
      <Property key="Caption" value="AMMO --"/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="TextColour" value="0.25 1 0.25"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>
    <Widget type="Button" skin="" position="8 230 1 1" align="Left Top" name="FatigueFrame">
      <Property key="Visible" value="false"/>
      <UserString key="ToolTipType" value="Layout"/>
      <UserString key="ToolTipLayout" value="HealthToolTip"/>
      <UserString key="ImageTexture_HealthImage" value="icons\k\fatigue.dds"/>
      <Widget type="ProgressBar" skin="MW_EnergyBar_Green" position="0 0 1 1" align="Left Top" name="Stamina">
        <Property key="Visible" value="false"/>
        <Property key="NeedMouse" value="false"/>
      </Widget>
    </Widget>
    <Widget type="TextBox" skin="ProgressText" position="470 44 42 24" name="StaminaValue" align="Left Top">
      <Property key="Visible" value="false"/>
      <Property key="Caption" value=""/>
      <Property key="TextAlign" value="Left VCenter"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>

    <!-- Equipped weapon box -->
    <Widget type="Button" skin="" position="444 44 42 48" align="Left Top" name="WeapBox">
      <Widget type="Widget" skin="HUD_Box" position="0 0 36 36">
        <Property key="NeedMouse" value="false"/>
        <Widget type="ItemWidget" skin="MW_ItemIconNoShadow" position="-3 -3 42 42" align="Left Top" name="WeapImage">
          <Property key="NeedMouse" value="false"/>
        </Widget>
      </Widget>
      <Widget type="ProgressBar" skin="MW_EnergyBar_Weapon" position="0 36 36 6" align="Left Bottom" name="WeapStatus">
        <Property key="NeedMouse" value="false"/>
      </Widget>
    </Widget>

    <!-- Selected spell box -->
    <Widget type="Button" position="488 44 42 48" align="Left Top" name="SpellBox">
      <Widget type="Widget" skin="HUD_Box" position="0 0 36 36">
        <Widget type="SpellWidget" skin="MW_ItemIconNoShadow" position="-3 -3 42 42" align="Left Top" name="SpellImage"/>
        <Property key="NeedMouse" value="false"/>
      </Widget>
      <Widget type="ProgressBar" skin="MW_EnergyBar_Magic" position="0 36 36 6" align="Left Bottom" name="SpellStatus">
        <Property key="NeedMouse" value="false"/>
      </Widget>
    </Widget>

    <!-- Sneak indicator box -->
    <Widget type="Button" skin="" position="488 88 36 36" align="Left Top" name="SneakBox">
      <Property key="Visible" value="false"/>
      <Widget type="Widget" skin="HUD_Box" position="0 0 36 36">
        <Property key="NeedMouse" value="false"/>
        <Widget type="ImageBox" skin="ImageBox" position="2 2 32 32" align="Left Top" name="SneakImage">
          <Property key="NeedMouse" value="false"/>
          <Property key="ImageTexture" value="icons\k\stealth_sneak.dds"/>
        </Widget>
      </Widget>
    </Widget>

    <!-- Spell effects box -->
    <Widget type="Widget" skin="HUD_Box_Transparent" position="0 0 20 20" align="Left Bottom" name="EffectBox">
    </Widget>
	
    <!-- Map box -->
    <Widget type="Widget" skin="" position="8 82 150 150" name="MiniMapBox" align="Left Top">
      <Widget type="Widget" skin="HUD_Box" position="0 0 150 150" align="Center">

        <Widget type="ScrollView" skin="MW_MapView" position="5 5 140 140" align="Left Top" name="MiniMap">
          <Widget type="ImageBox" skin="RotatingSkin" position="39 39 72 72" align="Top Left" name="Compass">
            <Property key="Visible" value="false"/>
            <Property key="ImageTexture" value="textures\compass.dds"/>
          </Widget>

          <Widget type="Button" skin="" position_real="0 0 1 1" name="MiniMapButton" align="Stretch">
            <Property key="Depth" value="10"/>
          </Widget>

        </Widget>

        <Widget type="TextBox" skin="ProgressText" position="39 63 72 24" name="CompassHeading" align="Top HCenter">
          <Property key="Caption" value="N"/>
          <Property key="Depth" value="20"/>
          <Property key="TextAlign" value="Center VCenter"/>
          <Property key="TextColour" value="0.25 1 0.25"/>
          <Property key="TextShadow" value="true"/>
          <Property key="TextShadowColour" value="0 0 0"/>
          <Property key="NeedMouse" value="false"/>
        </Widget>

      </Widget>
    </Widget>

    <!-- Drowning bar -->
    <Widget type="Widget" layer="DrowningBar" position="0 0 300 200" name="DrowningBar" align="Center Top">
        <Property key="Visible" value="false"/>
        <Widget type="Window" skin="MW_Dialog" position="0 36 230 58" align="Center Top" name="DrowningFrame">
            <Widget type="TextBox" skin="SandText" position="0 3 222 24" name="DrowningTitle" align="Center Top HStretch">
                <Property key="Caption" value="#{sBreath}"/>
                <Property key="TextAlign" value="Center"/>
                <Property key="TextShadow" value="true"/>
                <Property key="TextShadowColour" value="0 0 0"/>
            </Widget>
            <Widget type="Widget" skin="MW_Box" position="11 29 200 10" align="Stretch" name="BoundingBox"/>
            <Widget type="ProgressBar" skin="MW_Progress_Drowning_Full" position="13 31 196 6" align="Center Top" name="Drowning">
                <Property key="NeedMouse" value="false"/>
            </Widget>
            <Widget type="Widget" skin="MW_Progress_Drowning_Small" position="15 33 192 2" align="Center Top" name="Flash"/>
        </Widget>
    </Widget>

    <!-- Equipped weapon/selected spell name display for a few seconds after it changes -->
    <Widget type="TextBox" skin="SandText" position="168 118 344 24" name="WeaponSpellName" align="Left Top HStretch">
      <Property key="Visible" value="false"/>
      <Property key="TextAlign" value="Left"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>

    <!-- Cell name display when cell changes -->
    <Widget type="TextBox" skin="SandText" position="168 118 344 24" name="CellName" align="Left Top HStretch">
      <Property key="Visible" value="false"/>
      <Property key="TextAlign" value="Left"/>
      <Property key="TextShadow" value="true"/>
      <Property key="TextShadowColour" value="0 0 0"/>
      <Property key="NeedMouse" value="false"/>
    </Widget>

    <!-- Crosshair -->
    <Widget type="ImageBox" skin="HUD_Crosshair" position="0 0 32 32" align="Center Center" name="Crosshair">
    </Widget>

  </Widget>
</MyGUI>
